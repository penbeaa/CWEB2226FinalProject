@model IEnumerable<ClassStore.Domain.Entities.Class>

@{
    ViewBag.Title = "Index";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="panel panel-default">
    <div class="panel-heading">
        <h3>All Classes</h3>
    </div>

    <div class="panel-body">
        <table class="table table-striped table-condensed table-bordered">
            <tr>
                <th class="text-right">ID</th>
                <th>Name</th>
                <th class="text-right">Price</th>
                <th class="text-center">Action</th>
            </tr>

            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.ClassID</td>
                    <td>
                        @Html.ActionLink(item.Name, "Edit", new { item.ClassID })
                    </td>
                    <td>@item.Price.ToString("c")</td>
                    <td class="Text-center">
                        @using (Html.BeginForm("Delete", "Admin"))
                        {
                            @Html.Hidden("ClassID", item.ClassID)
                            <input type="submit"
                                   class="btn btn-primary"
                                   value="Delete" />
                        }
                    </td>
                </tr>
            }

        </table>
    </div>
    <div class="card-footer">
        @Html.ActionLink("Add a new product", "Create", null, new { @class = "btn btn-primary" })
    </div>
</div>

































