@model ClassStore.WebUI.Models.CartIndexViewModel

@{
    ViewBag.Title = "Class Store: Your Cart";
}
<style>
    #cartTable td 
    {
        vertical-align: middle;
    }
</style>


<h2>Your Shopping Cart</h2>

<table class="table">
    <thead>
        <tr>
            <th>Quantity</th>
            <th>Item</th>
            <th class="text-end">Price</th>
            <th class="text-end">Subtotal</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var line in Model.Cart.Lines)
         {
            <tr>
                <td class="text-center">@line.Quantity</td>
                <td>@line.Class.Name</td>
                <td class="text-end">@line.Class.Price.ToString("c")</td>
                <td class="text-end">@((line.Quantity * line.Class.Price).ToString("c"))</td>
                <td>
                    @using (Html.BeginForm("RemoveFromCart", "Cart"))
                    {
                        @Html.Hidden("ClassId", line.Class.ClassID)
                        @Html.HiddenFor(x => x.ReturnUrl)
                        <input type="submit" class="btn btn-warning" value="Remove" />
                    }
                </td>
            </tr>
         }
     </tbody>

    <tfoot>
        <tr>
            <td colspan="3" class="text-end">Total:</td>
            <td class="text-end"><strong>@Model.Cart.ComputeTotalValue().ToString("c")</strong></td>
        </tr>
    </tfoot>
</table>

<div class="text-center">
    <a class="btn btn-primary" href="@Model.ReturnUrl">
         Continue Shopping 
    </a>
    @Html.ActionLink("Checkout Now", "Checkout", null, new { @class = "btn btn-primary"})
</div>
