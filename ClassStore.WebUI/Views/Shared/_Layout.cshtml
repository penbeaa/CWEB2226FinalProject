<!DOCTYPE html>
<html>
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0">

    <link href="~/Content/bootstrap.css" rel="stylesheet" />
    <link href="~/Content/bootstrap-theme.css" rel="stylesheet" />
    <link href="~/Content/ErrorStyles.css" rel="stylesheet" />

    <title>@ViewBag.Title</title>
</head>

<body>
    <nav class="navbar navbar-dark" style="background-color: #D4AF37;">
        <a class="navbar-brand ms-4 fw-bold px-4" href="/Home/Index">
            CLASS STORE
        </a>
        @Html.Action("Summary", "Cart")
    </nav>

    <div class="row border p-4 justify-content-center align-items-center">

        <div id="categories" class="col-4 d-flex justify-content-center align-items-center text-center">
            @Html.Action("Menu", "Nav")
        </div>

        <div class="col-xs-8">
            @RenderBody()
        </div>

    </div>

</body>
</html>